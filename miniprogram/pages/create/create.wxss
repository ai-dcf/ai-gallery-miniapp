.create-page {
  min-height: 100vh;
  background: var(--td-bg);
}

.create-scroll {
  height: 100vh;
}

.input-section {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--td-text);
}

.prompt-textarea {
  width: 100% !important;
  background: var(--td-bg) !important;
  border-radius: 16rpx !important;
  margin-bottom: 24rpx !important;
}

.style-section {
  margin-bottom: 24rpx;
}

.style-label {
  font-size: 20rpx;
  color: var(--td-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  background: var(--td-bg);
  border: 2rpx solid var(--td-border);
}

.style-tag--active {
  background: var(--brand-color-light);
  border-color: rgba(0, 82, 217, 0.3);
}

.style-tag-text {
  font-size: 24rpx;
  color: #666;
}

.style-tag--active .style-tag-text {
  color: var(--brand-color);
}

.negative-section {
  margin-bottom: 24rpx;
}

.negative-label {
  font-size: 20rpx;
  color: var(--td-text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.negative-input {
  background: var(--td-bg) !important;
  border-radius: 16rpx !important;
}

.inspiration-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.inspiration-label {
  font-size: 20rpx;
  color: var(--td-warning);
  font-weight: 500;
}

.inspiration-desc {
  font-size: 20rpx;
  color: var(--td-text-secondary);
  margin-left: 4rpx;
}

.generate-btn-wrapper {
  margin: 0 32rpx 32rpx;
}

.generating-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.generating-indicator {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pulse-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 4rpx solid var(--brand-color);
  animation: pulse-ring 1.2s ease-out infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(1.6); opacity: 0; }
}

.pulse-icon-bg {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--brand-color-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.generating-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text);
  margin-bottom: 8rpx;
}

.generating-subtitle {
  font-size: 24rpx;
  color: var(--td-text-secondary);
  margin-bottom: 40rpx;
}

.generating-preview {
  width: 100%;
  height: 384rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.shimmer-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, var(--td-border) 25%, var(--td-bg) 50%, var(--td-border) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  display: flex;
  align-items: center;
  justify-content: center;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.progress-bar-wrapper {
  width: 100%;
}

.progress-bar-track {
  width: 100%;
  height: 12rpx;
  background: var(--td-bg);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--brand-color);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--td-text-secondary);
  margin-top: 16rpx;
}

.complete-section {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  animation: fadeIn 0.4s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}

.complete-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.complete-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--td-success);
}

.result-image-wrapper {
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.result-image {
  width: 100%;
  aspect-ratio: 1;
}

.prompt-card {
  background: var(--td-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.prompt-card-label {
  display: block;
  font-size: 20rpx;
  color: var(--td-text-secondary);
  margin-bottom: 8rpx;
}

.prompt-card-text {
  font-size: 24rpx;
  color: var(--td-text);
  line-height: 1.6;
}

.complete-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1 !important;
}

.publish-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--brand-color-light);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.publish-hint-text {
  font-size: 22rpx;
  color: var(--brand-color);
}

.bottom-spacer {
  height: 48rpx;
}
