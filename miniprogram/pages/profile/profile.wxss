.profile-page {
  min-height: 100vh;
  background: var(--td-bg);
  padding-bottom: calc(env(safe-area-inset-bottom, 0) + 128rpx);
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e5e5e5;
  border-top-color: var(--brand-color, #0052D9);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--td-text-secondary);
}

.not-logged-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 64rpx;
  background: #fff;
}

.avatar-placeholder {
  margin-bottom: 32rpx;
}

.login-hint {
  font-size: 28rpx;
  color: var(--td-text-secondary);
  margin-bottom: 48rpx;
}

.login-btn-wrapper {
  width: 100%;
  max-width: 520rpx;
}

.empty-gallery-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 80rpx 0;
}

.empty-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-text {
  font-size: 24rpx;
  color: var(--td-text-placeholder);
}

.profile-form-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 64rpx;
  background: #fff;
}

.form-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--td-text);
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 26rpx;
  color: var(--td-text-secondary);
  margin-bottom: 64rpx;
}

.avatar-choose-wrapper {
  margin-bottom: 48rpx;
}

.avatar-choose-btn {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: var(--td-bg);
  border: 4rpx dashed #d5d5d5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  line-height: normal;
}

.avatar-choose-btn::after {
  border: none;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-choose-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.avatar-choose-text {
  font-size: 22rpx;
  color: #ccc;
}

.nickname-input-wrapper {
  width: 100%;
  max-width: 520rpx;
  margin-bottom: 48rpx;
  background: var(--td-bg);
  border-radius: 16rpx;
  padding: 0 32rpx;
}

.nickname-input {
  height: 88rpx;
  font-size: 30rpx;
  color: var(--td-text);
}

.submit-btn-wrapper {
  width: 100%;
  max-width: 520rpx;
}

.logged-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(180deg, var(--brand-color) 0%, #2563eb 100%);
}

.user-info-section {
  position: relative;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 112rpx 40rpx 0;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-bio {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-stats {
  position: relative;
  display: flex;
  gap: 64rpx;
  padding: 40rpx 40rpx 80rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.gallery-card {
  margin: -32rpx 32rpx 24rpx;
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.gallery-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.gallery-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--td-text);
}

.gallery-more {
  font-size: 20rpx;
  color: var(--brand-color);
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.gallery-grid-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  gap: 16rpx;
}

.gallery-empty-text {
  font-size: 24rpx;
  color: var(--td-text-placeholder);
}

.gallery-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: rgba(0, 82, 217, 0.06);
}

.gallery-add-text {
  font-size: 26rpx;
  color: #0052D9;
}

.add-text {
  font-size: 20rpx;
  color: var(--td-text-placeholder);
}

.menu-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-cell-logout {
  color: #e34d59;
}
