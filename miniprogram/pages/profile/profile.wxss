.profile-page {
  min-height: 100vh;
  background: var(--td-bg);
  padding-bottom: calc(env(safe-area-inset-bottom, 0) + 128rpx);
}

.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e5e5e5;
  border-top-color: var(--brand-color, #0052D9);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--td-text-secondary);
}

.not-logged-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 64rpx;
  background: #fff;
}

.avatar-placeholder {
  margin-bottom: 32rpx;
}

.login-hint {
  font-size: 28rpx;
  color: var(--td-text-secondary);
  margin-bottom: 48rpx;
}

.login-btn-wrapper {
  width: 100%;
  max-width: 520rpx;
}

.empty-gallery-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 80rpx 0;
}

.empty-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-text {
  font-size: 24rpx;
  color: var(--td-text-placeholder);
}

.logged-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(180deg, var(--brand-color) 0%, #2563eb 100%);
}

.user-info-section {
  position: relative;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 112rpx 40rpx 0;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.edit-avatar-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: var(--brand-color, #0052D9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.edit-profile-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
}

.edit-profile-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-bio {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-stats {
  position: relative;
  display: flex;
  gap: 64rpx;
  padding: 40rpx 40rpx 80rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.gallery-card {
  margin: -32rpx 32rpx 24rpx;
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.gallery-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.gallery-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--td-text);
}

.gallery-more {
  font-size: 20rpx;
  color: var(--brand-color);
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.gallery-grid-item {
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  gap: 16rpx;
}

.gallery-empty-text {
  font-size: 24rpx;
  color: var(--td-text-placeholder);
}

.gallery-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: rgba(0, 82, 217, 0.06);
}

.gallery-add-text {
  font-size: 26rpx;
  color: #0052D9;
}

.add-text {
  font-size: 20rpx;
  color: var(--td-text-placeholder);
}

.menu-card {
  margin: 0 32rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-cell-logout {
  color: #e34d59;
}

.edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-modal {
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.edit-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--td-text);
}

.edit-modal-close {
  padding: 8rpx;
}

.edit-modal-body {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.edit-avatar-wrapper {
  margin-bottom: 32rpx;
}

.edit-avatar-btn-choose {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: var(--td-bg);
  position: relative;
  overflow: hidden;
  line-height: normal;
}

.edit-avatar-btn-choose::after {
  border: none;
}

.edit-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 4rpx dashed #d5d5d5;
  border-radius: 50%;
  box-sizing: border-box;
}

.edit-avatar-placeholder-text {
  font-size: 22rpx;
  color: #ccc;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
}

.edit-avatar-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-field {
  width: 100%;
}

.edit-field-label {
  font-size: 26rpx;
  color: var(--td-text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.edit-field-input-wrap {
  background: var(--td-bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.edit-field-input {
  height: 80rpx;
  font-size: 28rpx;
  color: var(--td-text);
}

.edit-modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 32rpx 32rpx;
}

.edit-modal-footer .t-button {
  flex: 1;
}

.preview-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-content {
  position: relative;
  width: 90vw;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-close {
  position: absolute;
  top: -64rpx;
  right: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.preview-image {
  width: 100%;
  border-radius: 16rpx;
}

.preview-prompt {
  width: 100%;
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.preview-prompt-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
}

.preview-prompt-text {
  font-size: 26rpx;
  color: #fff;
  line-height: 1.6;
}
