<view class="home-page">
  <scroll-view
    class="gallery-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onScrollToLower"
    lower-threshold="200"
  >
    <view class="gallery-waterfall" wx:if="{{galleryList.length > 0}}">
      <view class="waterfall-column waterfall-left">
        <view
          class="gallery-card"
          wx:for="{{galleryList}}"
          wx:if="{{index % 2 === 0}}"
          wx:key="_id"
        >
          <image
            class="card-image"
            src="{{item.imageUrl}}"
            mode="widthFix"
            lazy-load
            data-id="{{item._id}}"
            bindtap="onImageTap"
          />
          <view class="card-info">
            <text class="card-prompt">{{item.prompt}}</text>
            <view class="card-actions">
              <view class="action-btn" data-id="{{item._id}}" catchtap="onLikeTap">
                <t-icon
                  name="{{item.isLiked ? 'thumb-up-filled' : 'thumb-up'}}"
                  size="36rpx"
                  color="{{item.isLiked ? '#0052D9' : '#BBBBBB'}}"
                />
                <text class="action-count {{item.isLiked ? 'action-active' : ''}}">{{item.like_count}}</text>
              </view>
              <view class="action-btn" data-id="{{item._id}}" catchtap="onCollectTap">
                <t-icon
                  name="{{item.isCollected ? 'star-filled' : 'star'}}"
                  size="36rpx"
                  color="{{item.isCollected ? '#ED7B2F' : '#BBBBBB'}}"
                />
                <text class="action-count {{item.isCollected ? 'action-collect-active' : ''}}">{{item.collect_count}}</text>
              </view>
            </view>
            <view class="card-author">
              <image class="author-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text class="author-name">{{item.nickName}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="waterfall-column waterfall-right">
        <view
          class="gallery-card"
          wx:for="{{galleryList}}"
          wx:if="{{index % 2 === 1}}"
          wx:key="_id"
        >
          <image
            class="card-image"
            src="{{item.imageUrl}}"
            mode="widthFix"
            lazy-load
            data-id="{{item._id}}"
            bindtap="onImageTap"
          />
          <view class="card-info">
            <text class="card-prompt">{{item.prompt}}</text>
            <view class="card-actions">
              <view class="action-btn" data-id="{{item._id}}" catchtap="onLikeTap">
                <t-icon
                  name="{{item.isLiked ? 'thumb-up-filled' : 'thumb-up'}}"
                  size="36rpx"
                  color="{{item.isLiked ? '#0052D9' : '#BBBBBB'}}"
                />
                <text class="action-count {{item.isLiked ? 'action-active' : ''}}">{{item.like_count}}</text>
              </view>
              <view class="action-btn" data-id="{{item._id}}" catchtap="onCollectTap">
                <t-icon
                  name="{{item.isCollected ? 'star-filled' : 'star'}}"
                  size="36rpx"
                  color="{{item.isCollected ? '#ED7B2F' : '#BBBBBB'}}"
                />
                <text class="action-count {{item.isCollected ? 'action-collect-active' : ''}}">{{item.collect_count}}</text>
              </view>
            </view>
            <view class="card-author">
              <image class="author-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text class="author-name">{{item.nickName}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="gallery-empty" wx:if="{{!loading && galleryList.length === 0}}">
      <t-icon name="image" size="96rpx" color="#D5D5D5" />
      <text class="gallery-empty-text">还没有作品，快去创作吧</text>
    </view>

    <view class="loading-footer" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="40rpx" text="加载更多画作..." />
    </view>

    <view class="no-more" wx:if="{{!hasMore && galleryList.length > 0}}">
      <text class="no-more-text">— 已经到底了 —</text>
    </view>

    <view class="scroll-bottom-spacer"></view>
  </scroll-view>

  <view class="fab-btn" bindtap="onFabTap">
    <t-icon name="add" size="48rpx" color="#fff" />
  </view>

  <view class="loading-mask" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" />
  </view>
</view>
